# Environment: development, staging, production
NODE_ENV=development

# Application
APP_NAME=Webnestic School ERP
APP_URL=http://localhost:3000
API_URL=http://localhost:5000

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend API
API_PORT=5000

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=webnestic_saas
DB_USER=webnestic
DB_PASSWORD=webnestic123
DB_ROOT_PASSWORD=root123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_URL=redis://:redis123@redis:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_EXPIRE=7d

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET=webnestic-bucket

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# SMS Gateway
SMS_GATEWAY_API_KEY=your-sms-api-key
SMS_GATEWAY_SENDER_ID=WEBNESTIC

# WhatsApp API
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_BUSINESS_ACCOUNT_ID=your-account-id

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@webnestic.com

# 2FA
TWO_FACTOR_AUTH_ENABLED=true
TWO_FACTOR_AUTH_WINDOW=0

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# Session
SESSION_SECRET=your-session-secret-key
SESSION_TIMEOUT=86400

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
